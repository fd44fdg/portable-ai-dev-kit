{
  "schemaVersion": 1,
  "networkModes": {
    "global": {
      "npmRegistry": "https://registry.npmjs.org/",
      "archiveSource": "global"
    },
    "china": {
      "npmRegistry": "https://registry.npmmirror.com/",
      "archiveSource": "china"
    }
  },
  "tools": [
    {
      "id": "node",
      "name": "Node.js",
      "kind": "runtime",
      "required": true,
      "basePath": "apps/node",
      "versionCommand": ["node.exe", "--version"],
      "hostVersionCommand": ["node", "--version"],
      "binPaths": ["node.exe"],
      "install": {
        "type": "archive",
        "archiveName": "node-v24.11.1-win-x64.zip",
        "installerType": "zip",
        "urls": {
          "global": "https://nodejs.org/dist/v24.11.1/node-v24.11.1-win-x64.zip",
          "china": "https://npmmirror.com/mirrors/node/v24.11.1/node-v24.11.1-win-x64.zip"
        }
      }
    },
    {
      "id": "git",
      "name": "Git",
      "kind": "runtime",
      "required": true,
      "basePath": "apps/git",
      "versionCommand": ["cmd/git.exe", "--version"],
      "hostVersionCommand": ["git", "--version"],
      "binPaths": ["cmd/git.exe", "mingw64/bin/git.exe", "bin/git.exe"],
      "install": {
        "type": "archive",
        "archiveName": "mingit-2.53.0.2-64-bit.zip",
        "installerType": "zip",
        "urls": {
          "global": "https://github.com/git-for-windows/git/releases/download/v2.53.0.windows.2/MinGit-2.53.0.2-64-bit.zip",
          "china": "https://github.com/git-for-windows/git/releases/download/v2.53.0.windows.2/MinGit-2.53.0.2-64-bit.zip"
        }
      }
    },
    {
      "id": "codex",
      "name": "Codex CLI",
      "kind": "ai-cli",
      "required": false,
      "basePath": "tools/codex",
      "packageName": "@openai/codex@latest",
      "versionCommand": ["node_modules/.bin/codex.cmd", "--version"],
      "hostVersionCommand": ["codex", "--version"],
      "binPaths": ["node_modules/.bin/codex.cmd", "bin/codex.cmd", "bin/codex.exe"],
      "runCommand": ["node_modules/.bin/codex.cmd"],
      "loginCommand": ["node_modules/.bin/codex.cmd", "login"],
      "install": {
        "type": "npm",
        "dependsOn": ["node"]
      }
    },
    {
      "id": "claude",
      "name": "Claude Code",
      "kind": "ai-cli",
      "required": false,
      "basePath": "tools/claude",
      "packageName": "@anthropic-ai/claude-code@latest",
      "versionCommand": ["node_modules/.bin/claude.cmd", "--version"],
      "hostVersionCommand": ["claude", "--version"],
      "binPaths": ["node_modules/.bin/claude.cmd"],
      "runCommand": ["node_modules/.bin/claude.cmd"],
      "loginCommand": ["node_modules/.bin/claude.cmd"],
      "install": {
        "type": "npm",
        "dependsOn": ["node"]
      }
    },
    {
      "id": "gemini",
      "name": "Gemini CLI",
      "kind": "ai-cli",
      "required": false,
      "basePath": "tools/gemini",
      "packageName": "@google/gemini-cli@latest",
      "versionCommand": ["node_modules/.bin/gemini.cmd", "--version"],
      "hostVersionCommand": ["gemini", "--version"],
      "binPaths": ["node_modules/.bin/gemini.cmd"],
      "runCommand": ["node_modules/.bin/gemini.cmd"],
      "loginCommand": ["node_modules/.bin/gemini.cmd"],
      "install": {
        "type": "npm",
        "dependsOn": ["node"]
      }
    }
  ]
}
